,"mask":false,"rows":3,"type":"textarea","input":true,"label":"Raw Token (for jwt.io)","addons":[],"editor":"","hidden":false,"prefix":"","suffix":"","unique":false,"widget":{"type":"input"},"dbIndex":false,"overlay":{"top":"","left":"","style":"","width":"","height":""},"tooltip":"","wysiwyg":false,"disabled":true,"multiple":false,"redrawOn":"","tabindex":"","validate":{"custom":"","unique":false,"pattern":"","maxWords":"","minWords":"","multiple":false,"required":false,"maxLength":"","minLength":"","customPrivate":false,"strictDateValidation":false},"autofocus":false,"encrypted":false,"fixedSize":true,"hideLabel":false,"inputMask":"","inputType":"text","modalEdit":false,"protected":false,"refreshOn":"","tableView":true,"attributes":{},"autoExpand":false,"errorLabel":"","persistent":true,"properties":{},"spellcheck":true,"validateOn":"change","clearOnHide":true,"conditional":{"eq":"","show":null,"when":null},"customClass":"","description":"Copy this value and paste into jwt.io to inspect","displayMask":"","inputFormat":"html","placeholder":"","defaultValue":null,"dataGridLabel":false,"labelPosition":"top","showCharCount":false,"showWordCount":false,"calculateValue":"","calculateServer":false,"allowMultipleMasks":false,"customDefaultValue":"","allowCalculateOverride":false,"truncateMultipleSpaces":false},{"id":"eqe8ha","key":"tokenListener","tag":"div","type":"htmlelement","attrs":[],"input":false,"label":"Token Listener","logic":[{"name":"Setup Token Listener","actions":[{"name":"listenForTokenRefresh","type":"customAction","customAction":"if (instance.root._tokenListenerSetup) return;\ninstance.root._tokenListenerSetup = true;\n\nfunction decodeJwt(token) {\n  try {\n    var parts = token.split('.');\n    if (parts.length !== 3) return null;\n    var payload = parts[1];\n    var decoded = atob(payload.replace(/-/g, '+').replace(/_/g, '/'));\n    return JSON.parse(decoded);\n  } catch (e) {\n    return null;\n  }\n}\n\nfunction formatLocalTime(unixTimestamp) {\n  if (!unixTimestamp) return 'N/A';\n  var date = new Date(unixTimestamp * 1000);\n  return date.toLocaleString();\n}\n\nfunction updateTokenDisplay(eventType) {\n  var rootForm = instance.root;\n  var headers = (rootForm.options && rootForm.options.evalContext && rootForm.options.evalContext.headers) ? rootForm.options.evalContext.headers : {};\n  var authHeader = headers.Authorization || '';\n  var token = authHeader.replace('Bearer ', '');\n  var timestamp = new Date().toISOString();\n  \n  var decoded = decodeJwt(token);\n  \n  var timesField = rootForm.getComponent('tokenTimes');\n  if (timesField && decoded) {\n    var timesText = 'auth_time: ' + formatLocalTime(decoded.auth_time) + '\\n';\n    timesText += 'iat (issued): ' + formatLocalTime(decoded.iat) + '\\n';\n    timesText += 'exp (expires): ' + formatLocalTime(decoded.exp);\n    timesField.setValue(timesText);\n  } else if (timesField) {\n    timesField.setValue('No token or unable to decode');\n  }\n  \n  var tokenField = rootForm.getComponent('decodedToken');\n  if (tokenField) {\n    var displayText = decoded ? JSON.stringify(decoded, null, 2) : (token || 'No token');\n    tokenField.setValue(displayText);\n  }\n  \n  var rawField = rootForm.getComponent('rawToken');\n  if (rawField) {\n    rawField.setValue(token || 'No token');\n  }\n  \n  var logField = rootForm.getComponent('refreshLog');\n  if (logField) {\n    var currentLog = logField.getValue() || '';\n    var expiry = decoded && decoded.exp ? formatLocalTime(decoded.exp) : 'unknown';\n    var newEntry = '[' + timestamp + '] ' + eventType + ' (expires: ' + expiry + ')';\n    logField.setValue(currentLog + newEntry + '\\n');\n  }\n}\n\nupdateTokenDisplay('Initial load');\n\nvar viewer = document.querySelector('chefs-form-viewer');\nif (viewer) {\n  viewer.addEventListener('formio:userTokenRefreshed', function(e) {\n    updateTokenDisplay('TOKEN REFRESHED');\n  });\n  viewer.addEventListener('formio:userTokenExpiring', function(e) {\n    var logField = instance.root.getComponent('refreshLog');\n    if (logField) {\n      var currentLog = logField.getValue() || '';\n      logField.setValue(currentLog + '[' + new Date().toISOString() + '] WARNING: Token expiring soon!\\n');\n    }\n  });\n  console.log('[Token Listener] Active');\n}\n"}],"trigger":{"type":"javascript","javascript":"return true;"}}],"addons":[],"hidden":false,"prefix":"","suffix":"","unique":false,"widget":null,"content":"","dbIndex":false,"overlay":{"top":"","left":"","style":"","width":"","height":""},"tooltip":"","disabled":false,"multiple":false,"redrawOn":"","tabindex":"","validate":{"custom":"","unique":false,"multiple":false,"required":false,"customPrivate":false,"strictDateValidation":false},"autofocus":false,"encrypted":false,"hideLabel":false,"modalEdit":false,"protected":false,"refreshOn":"","tableView":false,"attributes":{},"errorLabel":"","persistent":false,"properties":{},"validateOn":"change","clearOnHide":true,"conditional":{"eq":"","show":null,"when":null},"customClass":"","description":"","placeholder":"","defaultValue":null,"dataGridLabel":false,"labelPosition":"top","showCharCount":false,"showWordCount":false,"calculateValue":"","calculateServer":false,"refreshOnChange":false,"allowMultipleMasks":false,"customDefaultValue":"","allowCalculateOverride":false},{"id":"erdfqw8","key":"submit","size":"md","type":"button","block":false,"input":true,"label":"Submit","theme":"primary","action":"submit","addons":[],"hidden":false,"prefix":"","suffix":"","unique":false,"widget":{"type":"input"},"dbIndex":false,"overlay":{"top":"","left":"","style":"","width":"","height":""},"tooltip":"","disabled":false,"leftIcon":"","multiple":false,"redrawOn":"","tabindex":"","validate":{"custom":"","unique":false,"multiple":false,"required":false,"customPrivate":false,"strictDateValidation":false},"autofocus":false,"encrypted":false,"hideLabel":false,"modalEdit":false,"protected":false,"refreshOn":"","rightIcon":"","tableView":false,"attributes":{},"